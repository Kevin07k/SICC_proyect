# Init y FDW (database/)
# Valores para desarrollo local: API e init corren en el HOST, BDs en Docker (puertos publicados).

# PostgreSQL — Santa Cruz
PG_HOST=localhost
PG_PORT=5432
PG_DB=sicc_central
PG_USER=sicc_admin
PG_PASSWORD=sicc_pg_pass_2024

# MySQL — Cochabamba
MYSQL_HOST=localhost
MYSQL_PORT=3306
MYSQL_DB=sicc_cochabamba
MYSQL_USER=sicc_admin
MYSQL_PASSWORD=sicc_mysql_pass_2024
MYSQL_ROOT_PASSWORD=sicc_root_pass_2024

# Host visto desde el contenedor PostgreSQL hacia MySQL (red Docker)
MYSQL_FDW_HOST=mysql-secundaria
MYSQL_FDW_USER=sicc_fdw_ro
MYSQL_FDW_PASSWORD=sicc_fdw_ro_pass_2024

# MongoDB — Santa Cruz (puerto host 27017)
MONGO_SC_HOST=localhost
MONGO_SC_PORT=27017
MONGO_SC_DB=sicc_sc
MONGO_SC_USER=sicc_mongo_api
MONGO_SC_PASSWORD=sicc_mongo_api_pass_2024

# MongoDB — Cochabamba (puerto host 27018 → 27017 en contenedor)
MONGO_CB_HOST=localhost
MONGO_CB_PORT=27018
MONGO_CB_DB=sicc_cb
MONGO_CB_USER=sicc_mongo_api
MONGO_CB_PASSWORD=sicc_mongo_api_pass_2024

# Root Mongo (solo init / administración)
MONGO_ROOT_USER=sicc_mongo_admin
MONGO_ROOT_PASSWORD=sicc_mongo_pass_2024

# Si init corre desde el host y FDW falla, probar MYSQL_FDW_HOST=localhost
# Si la API corre en Docker: PG_HOST=host.docker.internal, MYSQL_HOST=host.docker.internal,
#   MONGO_SC_HOST=host.docker.internal, MONGO_CB_HOST=host.docker.internal
