# API SICC
DEBUG=true
CORS_ORIGINS=http://localhost:3000,http://127.0.0.1:3000

# PostgreSQL — Sede Central (Santa Cruz)
# Desarrollo local: BDs en Docker, API en el host → localhost
PG_HOST=localhost
PG_PORT=5432
PG_DB=sicc_central
PG_USER=sicc_api
PG_PASSWORD=sicc_api_pass_2024

# MySQL — Sucursal Cochabamba
MYSQL_HOST=localhost
MYSQL_PORT=3306
MYSQL_DB=sicc_cochabamba
MYSQL_USER=sicc_api
MYSQL_PASSWORD=sicc_api_pass_2024
# MYSQL_SSL=false

# MongoDB — Santa Cruz (documentos locales)
MONGO_SC_HOST=localhost
MONGO_SC_PORT=27017
MONGO_SC_DB=sicc_sc
MONGO_SC_USER=sicc_mongo_api
MONGO_SC_PASSWORD=sicc_mongo_api_pass_2024

# MongoDB — Cochabamba (documentos locales)
MONGO_CB_HOST=localhost
MONGO_CB_PORT=27018
MONGO_CB_DB=sicc_cb
MONGO_CB_USER=sicc_mongo_api
MONGO_CB_PASSWORD=sicc_mongo_api_pass_2024

# Init/migraciones (no usar en la API): sicc_admin / sicc_pg_pass_2024

# IDs de sede (catálogo replicado)
SEDE_CENTRAL_ID=1
SEDE_SECUNDARIA_ID=2

# Reportes globales: segundos que el resultado permanece en caché (PostgreSQL)
REPORTES_CACHE_TTL_SECONDS=300

# Docker: API en contenedor, BDs en el host o en compose de database/
# PG_HOST=host.docker.internal
# MYSQL_HOST=host.docker.internal
# MONGO_SC_HOST=host.docker.internal
# MONGO_CB_HOST=host.docker.internal
