    PG_INC -.->|incidente_uuid| PG_TL
    PG_ACT -.->|activo_uuid| PG_TEL

    MY_INC -.->|incidente_uuid| MY_EVID
    MY_INC -.->|incidente_uuid| MY_TL
    MY_ACT -.->|activo_uuid| MY_TEL

    R_USERS -.-> PG
