        PG_EVID[Evidencias incidente]
        PG_TL[Timeline eventos]
        PG_TEL[Telemetria activo]

        MONGO_PG --> PG_EVID
        MONGO_PG --> PG_TL
        MONGO_PG --> PG_TEL
    end

    subgraph SECONDARY["MySQL - datos locales Cochabamba"]
        MYSQL[("MySQL")]
        MY_INC[Incidentes]
        MY_ACT[Activos]
        MY_BIT[Bitacora]

        MYSQL --> MY_INC
        MYSQL --> MY_ACT
        MYSQL --> MY_BIT
    end

    subgraph MONGO_CB["MongoDB - documentos locales Cochabamba"]
        MONGO_MY[("MongoDB")]
        MY_EVID[Evidencias incidente]
        MY_TL[Timeline eventos]
